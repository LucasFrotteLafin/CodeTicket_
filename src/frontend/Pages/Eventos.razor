@page "/eventos"
@inject ApiService Api
@inject ISnackbar Snackbar

<PageTitle>CodeTicket — Eventos</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1 fw-bold">Eventos 🎪</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-6 mud-text-secondary">
    Cadastre novos eventos no sistema.
</MudText>

<MudGrid Spacing="4" Justify="Justify.Center">
    <MudItem xs="12" sm="10" md="7" lg="6">
        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Class="mr-2" />
                        <MudText Typo="Typo.h6" Class="fw-bold">Novo Evento</MudText>
                    </div>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_model.Nome"
                              Label="Nome do Evento"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.MusicNote"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.UsuarioCpf"
                              Label="CPF do Usuário"
                              HelperText="Somente números, 11 dígitos"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              MaxLength="11"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.Local"
                              Label="Local"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.LocationOn"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.Descricao"
                              Label="Descrição"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Class="mb-3" />

                <MudTextField @bind-Value="_model.ImagemUrl"
                              Label="URL da Imagem"
                              HelperText="Link direto para uma imagem (jpg, png...)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Image"
                              Class="mb-3" />

                <MudNumericField @bind-Value="_model.CapacidadeTotal"
                                 Label="Capacidade Total"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.People"
                                 Min="1"
                                 Class="mb-3" />

                <MudDatePicker @bind-Date="_model.DataEvento"
                               Label="Data do Evento"
                               Variant="Variant.Outlined"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                               Class="mb-3" />

                <MudNumericField @bind-Value="_model.PrecoPadrao"
                                 Label="Preço Padrão (R$)"
                                 Variant="Variant.Outlined"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                 Format="F2"
                                 Min="0.01m"
                                 Class="mb-3" />
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4">
                <MudButton OnClick="Cadastrar"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="_carregando"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_carregando)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Salvando...</span>
                    }
                    else
                    {
                        <span>Cadastrar Evento</span>
                    }
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private CriarEventoModel _model = new();
    private bool _carregando = false;

    private async Task Cadastrar()
    {
        if (string.IsNullOrWhiteSpace(_model.Nome))
        {
            Snackbar.Add("Informe o nome do evento.", Severity.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(_model.UsuarioCpf))
        {
            Snackbar.Add("Informe o CPF do usuário.", Severity.Warning);
            return;
        }
        if (_model.DataEvento == null)
        {
            Snackbar.Add("Informe a data do evento.", Severity.Warning);
            return;
        }

        _carregando = true;
        var (sucesso, mensagem) = await Api.CriarEvento(_model);

        if (sucesso)
        {
            Snackbar.Add(mensagem, Severity.Success);
            _model = new();
        }
        else
        {
            Snackbar.Add(mensagem, Severity.Error);
        }

        _carregando = false;
    }
}
