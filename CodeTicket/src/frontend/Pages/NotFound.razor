@page "/404"

<PageTitle>Página não encontrada</PageTitle>

<div class="d-flex flex-column align-center justify-center" style="min-height: 60vh;">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 6rem;" Color="Color.Default" Class="mb-4" />
    <MudText Typo="Typo.h4" Class="fw-bold mb-2">Página não encontrada</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-6">
        A página que você está procurando não existe.
    </MudText>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">
        Voltar ao Início
    </MudButton>
</div>
